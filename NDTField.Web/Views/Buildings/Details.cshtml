@model NDTField.Web.Models.Building
@using System.Text.Json
@{
    ViewData["Title"] = Model.Name;

    var badgeClass = Model.SafetyStatus switch
    {
        "Safe" => "badge-safe",
        "Dangerous" => "badge-dangerous",
        _ => "badge-fair"
    };

    // Parse raw JSON for test tables
    JsonElement? root = null;
    JsonElement? schmidtTests = null;
    JsonElement? directUPVTests = null;
    JsonElement? indirectUPVTests = null;

    if (!string.IsNullOrEmpty(Model.RawJson))
    {
        var doc = JsonDocument.Parse(Model.RawJson);
        root = doc.RootElement;

        if (root.Value.TryGetProperty("schmidtTests", out var s))
            schmidtTests = s;
        if (root.Value.TryGetProperty("directUPVTests", out var d))
            directUPVTests = d;
        if (root.Value.TryGetProperty("indirectUPVTests", out var i))
            indirectUPVTests = i;
    }
}

<div style="max-width:960px">

    <!-- Back -->
    <div class="mb-3">
        <a asp-controller="Buildings" asp-action="Index"
               class="text-muted" style="font-size:0.8rem">
            ← Back to search
        </a>
    </div>

    <!-- Header card -->
    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                <div>
                    <h2 class="fw-bold mb-1">@Model.Name</h2>
                    <p class="text-muted mb-1" style="font-size:0.82rem">
                        @Model.Location
                    </p>
                    @if (!string.IsNullOrEmpty(Model.BuildingNumber))
                    {
                        <span class="badge bg-secondary"
                              style="font-size:0.72rem">
                            @Model.BuildingNumber
                        </span>
                    }
                </div>
                <div class="text-end">
                    <span class="status-badge @badgeClass">
                        @Model.SafetyStatus?.ToUpper()
                    </span>
                    <div class="mt-1 fw-bold" style="font-size:1.2rem">
                        @Model.SafetyScore
                        <span class="text-muted fw-normal"
                              style="font-size:0.8rem">/100</span>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Recommendation))
            {
                <div class="alert alert-light border mt-3 mb-0"
                     style="font-size:0.82rem">
                    <strong>Recommendation:</strong> @Model.Recommendation
                </div>
            }
        </div>
    </div>

    <!-- Info + breakdown row -->
    <div class="row g-3 mb-3">

        <!-- Building info -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="section-heading">Building Information</h6>
                    <table class="table table-sm info-table mb-0">
                        <tr>
                            <td class="text-muted">Client</td>
                            <td class="fw-semibold">
                                @(Model.ClientName ?? "—")
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted">Operator</td>
                            <td class="fw-semibold">
                                @(Model.Operator ?? "—")
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted">Date of Test</td>
                            <td class="fw-semibold">
                                @(Model.DateOfTest?.ToString("dd MMM yyyy") ?? "—")
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted">Uploaded</td>
                            <td class="fw-semibold">
                                @Model.UploadedAt.ToString("dd MMM yyyy, HH:mm")
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <!-- Test breakdown -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="section-heading">
                        Test Results — @Model.TotalTests Total
                    </h6>
                    <div class="row text-center g-2">
                        <div class="col">
                            <div class="breakdown-box bg-success-subtle">
                                <div class="breakdown-num text-success">
                                    @Model.ExcellentCount
                                </div>
                                <div class="breakdown-label">Excellent</div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="breakdown-box bg-primary-subtle">
                                <div class="breakdown-num text-primary">
                                    @Model.GoodCount
                                </div>
                                <div class="breakdown-label">Good</div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="breakdown-box bg-warning-subtle">
                                <div class="breakdown-num text-warning">
                                    @Model.MediumCount
                                </div>
                                <div class="breakdown-label">Medium</div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="breakdown-box bg-danger-subtle">
                                <div class="breakdown-num text-danger">
                                    @Model.DoubtfulCount
                                </div>
                                <div class="breakdown-label">Doubtful</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Schmidt Hammer Tests ── -->
    @if (schmidtTests.HasValue &&
     schmidtTests.Value.GetArrayLength() > 0)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="section-heading">
                    🔨 Schmidt Hammer Tests
                    <span class="test-count">
                        @schmidtTests.Value.GetArrayLength() tests
                    </span>
                </h6>

                @foreach (var t in schmidtTests.Value.EnumerateArray())
                {
                    var rating = t.TryGetProperty("qualityRating",
                        out var qr) ? qr.GetString() : "";
                    var status = t.TryGetProperty("complianceStatus",
                        out var cs) ? cs.GetString() : "";

                    <div class="test-card mb-2">
                        <div class="test-card-header">
                            <div>
                                <span class="fw-semibold">
                                    @(t.TryGetProperty("element",
                                        out var el) ? el.GetString() : "—")
                                </span>
                                <span class="text-muted ms-2" style="font-size:0.75rem">
                                    @(t.TryGetProperty("gridLocation",
                                        out var gl) ? gl.GetString() : "")
                                    ·
                                    @(t.TryGetProperty("floorLevel",
                                        out var fl) ? fl.GetString() : "")
                                </span>
                            </div>
                            <div class="d-flex gap-2 align-items-center">
                                <span class="rating-pill @GetRatingClass(rating)">
                                    @rating
                                </span>
                                <span class="@(status == "PASS" ? "text-success fw-bold" : "text-danger fw-bold")"
                                      style="font-size:0.78rem">
                                    @status
                                </span>
                            </div>
                        </div>
                        <div class="test-card-body">
                            <div class="test-stat">
                                <div class="test-stat-label">Avg Rebound</div>
                                <div class="test-stat-value">
                                    @(t.TryGetProperty("averageRebound",
                                        out var ar) ? ar.GetDouble().ToString("F1") : "—")
                                </div>
                            </div>
                            <div class="test-stat">
                                <div class="test-stat-label">f'c (MPa)</div>
                                <div class="test-stat-value fw-bold">
                                    @(t.TryGetProperty("correctedStrength",
                                        out var fc) ? fc.GetDouble().ToString("F1") : "—")
                                </div>
                            </div>
                            <div class="test-stat">
                                <div class="test-stat-label">Mean</div>
                                <div class="test-stat-value">
                                    @(t.TryGetProperty("mean",
                                        out var mn) ? mn.GetDouble().ToString("F1") : "—")
                                </div>
                            </div>
                            <div class="test-stat">
                                <div class="test-stat-label">Std Dev</div>
                                <div class="test-stat-value">
                                    @(t.TryGetProperty("stdDeviation",
                                        out var sd) ? sd.GetDouble().ToString("F1") : "—")
                                </div>
                            </div>
                            <div class="test-stat">
                                <div class="test-stat-label">CV%</div>
                                <div class="test-stat-value">
                                    @(t.TryGetProperty("coeffVariation",
                                        out var cv) ? cv.GetDouble().ToString("F1") : "—")
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- ── Direct UPV Tests ── -->
    @if (directUPVTests.HasValue &&
      directUPVTests.Value.GetArrayLength() > 0)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="section-heading">
                    📡 Direct UPV Tests
                    <span class="test-count">
                        @directUPVTests.Value.GetArrayLength() tests
                    </span>
                </h6>

                @foreach (var t in directUPVTests.Value.EnumerateArray())
                {
                    var rating = t.TryGetProperty("qualityRating",
                        out var qr) ? qr.GetString() : "";

                    <div class="test-card mb-2">
                        <div class="test-card-header">
                            <div>
                                <span class="fw-semibold">
                                    @(t.TryGetProperty("element",
                                        out var el) ? el.GetString() : "—")
                                </span>
                                <span class="text-muted ms-2" style="font-size:0.75rem">
                                    @(t.TryGetProperty("gridLocation",
                                        out var gl) ? gl.GetString() : "")
                                    ·
                                    @(t.TryGetProperty("floorLevel",
                                        out var fl) ? fl.GetString() : "")
                                </span>
                            </div>
                            <span class="rating-pill @GetRatingClass(rating)">
                                @rating
                            </span>
                        </div>
                        <div class="test-card-body">
                            <div class="test-stat">
                                <div class="test-stat-label">T1 (μs)</div>
                                <div class="test-stat-value">
                                    @(t.TryGetProperty("t1",
                                        out var t1) ? t1.GetDouble().ToString("F1") : "—")
                                </div>
                            </div>
                            <div class="test-stat">
                                <div class="test-stat-label">T2 (μs)</div>
                                <div class="test-stat-value">
                                    @(t.TryGetProperty("t2",
                                        out var t2) ? t2.GetDouble().ToString("F1") : "—")
                                </div>
                            </div>
                            <div class="test-stat">
                                <div class="test-stat-label">T3 (μs)</div>
                                <div class="test-stat-value">
                                    @(t.TryGetProperty("t3",
                                        out var t3) ? t3.GetDouble().ToString("F1") : "—")
                                </div>
                            </div>
                            <div class="test-stat">
                                <div class="test-stat-label">Distance (mm)</div>
                                <div class="test-stat-value">
                                    @(t.TryGetProperty("distance",
                                        out var di) ? di.GetDouble().ToString("F0") : "—")
                                </div>
                            </div>
                            <div class="test-stat">
                                <div class="test-stat-label">Velocity (km/s)</div>
                                <div class="test-stat-value fw-bold">
                                    @(t.TryGetProperty("pulseVelocity",
                                        out var pv) ? pv.GetDouble().ToString("F3") : "—")
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- ── Indirect UPV Tests ── -->
    @if (indirectUPVTests.HasValue &&
     indirectUPVTests.Value.GetArrayLength() > 0)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="section-heading">
                    📶 Indirect UPV Tests
                    <span class="test-count">
                        @indirectUPVTests.Value.GetArrayLength() tests
                    </span>
                </h6>

                @foreach (var t in indirectUPVTests.Value.EnumerateArray())
                {
                    var rating = t.TryGetProperty("qualityRating",
                        out var qr) ? qr.GetString() : "";
                    var homogeneity = t.TryGetProperty("homogeneityRating",
                        out var hr) ? hr.GetString() : "—";
                    var readingCount = t.TryGetProperty("readings",
                        out var rd) ? rd.GetArrayLength() : 0;

                    <div class="test-card mb-2">
                        <div class="test-card-header">
                            <div>
                                <span class="fw-semibold">
                                    @(t.TryGetProperty("element",
                                        out var el) ? el.GetString() : "—")
                                </span>
                                <span class="text-muted ms-2" style="font-size:0.75rem">
                                    @(t.TryGetProperty("gridLocation",
                                        out var gl) ? gl.GetString() : "")
                                    ·
                                    @(t.TryGetProperty("floorLevel",
                                        out var fl) ? fl.GetString() : "")
                                </span>
                            </div>
                            <span class="rating-pill @GetRatingClass(rating)">
                                @rating
                            </span>
                        </div>
                        <div class="test-card-body">
                            <div class="test-stat">
                                <div class="test-stat-label">Velocity (km/s)</div>
                                <div class="test-stat-value fw-bold">
                                    @(t.TryGetProperty("pulseVelocity",
                                        out var pv) ? pv.GetDouble().ToString("F3") : "—")
                                </div>
                            </div>
                            <div class="test-stat">
                                <div class="test-stat-label">R²</div>
                                <div class="test-stat-value">
                                    @(t.TryGetProperty("r2Value",
                                        out var r2) ? r2.GetDouble().ToString("F4") : "—")
                                </div>
                            </div>
                            <div class="test-stat">
                                <div class="test-stat-label">Homogeneity</div>
                                <div class="test-stat-value">@homogeneity</div>
                            </div>
                            <div class="test-stat">
                                <div class="test-stat-label">Readings</div>
                                <div class="test-stat-value">@readingCount pts</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- No test data -->
    @if ((!schmidtTests.HasValue || schmidtTests.Value.GetArrayLength() == 0) &&
         (!directUPVTests.HasValue || directUPVTests.Value.GetArrayLength() == 0) &&
         (!indirectUPVTests.HasValue || indirectUPVTests.Value.GetArrayLength() == 0))
    {
        <div class="card mb-3">
            <div class="card-body text-center text-muted py-4">
                <div class="fs-3 mb-2">📭</div>
                No detailed test data available in this report.
            </div>
        </div>
    }

</div>

@functions {
    string GetRatingClass(string? rating)
    {
        if (rating == null) return "rating-default";
        if (rating.Contains("Excellent")) return "rating-excellent";
        if (rating.Contains("Good")) return "rating-good";
        if (rating.Contains("Medium") ||
            rating.Contains("Fair")) return "rating-medium";
        if (rating.Contains("Doubtful") ||
            rating.Contains("Poor")) return "rating-doubtful";
        return "rating-default";
    }
}
@{
    ViewData["Title"] = "Home";
    var recent = ViewBag.Recent as List<NDTField.Web.Models.Building> ?? new();
}

<!-- Hero -->
<div class="hero-section mb-4">
    <div class="hero-text">
        <div class="hero-tag">NDT Structural Assessment</div>
        <h1 class="hero-title">Is Your Building Safe?</h1>
        <p class="hero-sub">
            Field Labs gives engineers and the public instant access to
            non-destructive test results for buildings across Kenya.
            Search any assessed building and see its structural safety status.
        </p>
        <div class="d-flex gap-2 flex-wrap mt-3">
            <a asp-controller="Buildings" asp-action="Index"
                   class="btn btn-success btn-sm px-4 py-2">
                🔍 Search Buildings
            </a>
            <a asp-controller="Buildings" asp-action="Upload"
                   class="btn btn-outline-success btn-sm px-4 py-2">
                📤 Upload Report
            </a>
        </div>
    </div>
    <div class="hero-illustration">⬡</div>
</div>

<!-- Stats row -->
<div class="stats-row mb-4">

    <div class="stat-card">
        <div class="stat-icon bg-slate">🏗️</div>
        <div>
            <div class="stat-number">@ViewBag.Total</div>
            <div class="stat-label">Buildings Assessed</div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon bg-green">✅</div>
        <div>
            <div class="stat-number text-success">@ViewBag.Safe</div>
            <div class="stat-label">Safe</div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon bg-amber">⚠️</div>
        <div>
            <div class="stat-number text-warning">@ViewBag.Fair</div>
            <div class="stat-label">Fair</div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon bg-red">🚨</div>
        <div>
            <div class="stat-number text-danger">@ViewBag.Dangerous</div>
            <div class="stat-label">Dangerous</div>
        </div>
    </div>

</div>

<!-- Two column layout -->
<div class="row g-3">

    <!-- Recent assessments -->
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold text-muted text-uppercase mb-0">
                        Recent Assessments
                    </h6>
                    <a asp-controller="Buildings" asp-action="Index"
                           class="btn btn-outline-success btn-sm">
                        View all →
                    </a>
                </div>

                @if (!recent.Any())
                {
                    <div class="text-center text-muted py-4">
                        <div class="fs-2 mb-2">📭</div>
                        <p class="mb-2">No buildings uploaded yet.</p>
                        <a asp-controller="Buildings" asp-action="Upload"
                               class="btn btn-success btn-sm">
                            Upload First Report
                        </a>
                    </div>
                }
                else
                {
                    @foreach (var b in recent)
                    {
                        var badgeClass = b.SafetyStatus switch
                        {
                            "Safe" => "badge-safe",
                            "Dangerous" => "badge-dangerous",
                            _ => "badge-fair"
                        };
                        var borderClass = b.SafetyStatus switch
                        {
                            "Safe" => "border-safe",
                            "Dangerous" => "border-dangerous",
                            _ => "border-fair"
                        };

                        <div class="recent-item @borderClass">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-semibold">@b.Name</div>
                                    <div class="text-muted" style="font-size:0.75rem">
                                        @b.Location
                                        — @(b.DateOfTest?.ToString("dd MMM yyyy") ?? "—")
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="status-badge @badgeClass">
                                        @b.SafetyStatus
                                    </span>
                                    <a asp-controller="Buildings"
                                           asp-action="Details"
                                           asp-route-id="@b.Id"
                                           class="btn btn-outline-secondary btn-sm">
                                        →
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- How it works -->
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="section-heading">Safety Status Key</h6>
                <div class="d-flex flex-column gap-3 mt-2">
                    <div class="safety-key-item border-safe">
                        <span class="status-badge badge-safe">Safe</span>
                        <div>
                            <div class="fw-semibold" style="font-size:0.82rem">Score 80–100</div>
                            <div class="text-muted" style="font-size:0.75rem">
                                All tested elements meet minimum structural requirements
                            </div>
                        </div>
                    </div>
                    <div class="safety-key-item border-fair">
                        <span class="status-badge badge-fair">Fair</span>
                        <div>
                            <div class="fw-semibold" style="font-size:0.82rem">Score 50–79</div>
                            <div class="text-muted" style="font-size:0.75rem">
                                Further investigation recommended for flagged elements
                            </div>
                        </div>
                    </div>
                    <div class="safety-key-item border-dangerous">
                        <span class="status-badge badge-dangerous">Dangerous</span>
                        <div>
                            <div class="fw-semibold" style="font-size:0.82rem">Score 0–49</div>
                            <div class="text-muted" style="font-size:0.75rem">
                                Immediate structural investigation required. Do not occupy.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Chart Section -->
    <div class="row g-3 mt-1">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    <h6 class="section-heading">Safety Status Breakdown</h6>
                    @if (ViewBag.Total > 0)
                    {
                        <div class="d-flex align-items-center justify-content-center" style="height:220px">
                            <canvas id="safetyChart"></canvas>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <div class="mb-2">📊</div>
                            No data yet — upload a report to see the chart
                        </div>
                    }
                </div>
            </div>
        </div>

       <div class="col-lg-6">
    <div class="card">
        <div class="card-body">
            <h6 class="section-heading">Summary</h6>
            <div class="summary-grid">
                <div class="summary-item">
                    <div class="summary-label">Total Buildings</div>
                    <div class="summary-value">@ViewBag.Total</div>
                </div>
                <div class="summary-item">
                    <div class="summary-label">Safe Buildings</div>
                    <div class="summary-value text-success">@ViewBag.Safe</div>
                </div>
                <div class="summary-item">
                    <div class="summary-label">Fair Buildings</div>
                    <div class="summary-value text-warning">@ViewBag.Fair</div>
                </div>
                <div class="summary-item">
                    <div class="summary-label">Dangerous Buildings</div>
                    <div class="summary-value text-danger">@ViewBag.Dangerous</div>
                </div>
                <div class="summary-item">
                    <div class="summary-label">Safe Rate</div>
                    <div class="summary-value">
                        @(ViewBag.Total > 0
                            ? $"{(int)((double)ViewBag.Safe / ViewBag.Total * 100)}%"
                            : "—")
                    </div>
                </div>
                <div class="summary-item">
                    <div class="summary-label">Risk Rate</div>
                    <div class="summary-value text-danger">
                        @(ViewBag.Total > 0
                            ? $"{(int)((double)ViewBag.Dangerous / ViewBag.Total * 100)}%"
                            : "—")
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
        <script>
            @if (ViewBag.Total > 0)
            {
                <text>
                    const ctx = document.getElementById('safetyChart').getContext('2d');
                    new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                    labels: ['Safe', 'Fair', 'Dangerous'],
                    datasets: [{
                    data: [@ViewBag.Safe, @ViewBag.Fair, @ViewBag.Dangerous],
                    backgroundColor: ['#22c55e', '#eab308', '#ef4444'],
                    borderColor:     ['#16a34a', '#ca8a04', '#dc2626'],
                    borderWidth: 2,
                    hoverOffset: 8
                    }]
                    },
                    options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '65%',
                    plugins: {
                    legend: {
                    position: 'bottom',
                    labels: {
                    font: { size: 11 },
                    padding: 16,
                    usePointStyle: true,
                    pointStyleWidth: 8
                    }
                    },
                    tooltip: {
                    callbacks: {
                    label: function(context) {
                    const total = context.dataset.data
                    .reduce((a, b) => a + b, 0);
                    const pct = Math.round(
                    context.parsed / total * 100);
                    return ` ${context.label}: ${context.parsed} (${pct}%)`;
                    }
                    }
                    }
                    }
                    }
                    });
                </text>
            }
        </script>
    }

</div>